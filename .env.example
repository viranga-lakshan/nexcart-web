# Local dev: Vite proxies /api and /uploads to localhost:5000
VITE_API_BASE_URL=/api/v1

# Do NOT set VITE_API_ORIGIN on Vercel — use relative /uploads paths
# so vercel.json can proxy images over HTTPS (avoids mixed-content errors).

# Production backend (proxied via vercel.json on deploy):
# http://51.20.151.235:5000

VITE_APP_NAME=NexCart
